#!/usr/bin/env python3
"""train.py — generated by Fine-Tuning OS
Project: {{ project_id }}

Standalone LoRA/QLoRA micro-training script.
Reads the synthetic dataset, trains for N steps, writes metrics JSON.

Usage:
    python src/train.py [--steps {{ steps }}]
"""
from __future__ import annotations

import argparse
import json
import math
import os
import time
from pathlib import Path


def _load_dataset(data_dir: Path) -> list[dict]:
    """Load JSONL synthetic dataset rows."""
    jsonl = data_dir / "synthetic" / "dataset.jsonl"
    if not jsonl.exists():
        raise FileNotFoundError(f"dataset not found: {jsonl}")
    rows = []
    with jsonl.open(encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if line:
                rows.append(json.loads(line))
    return rows


def _simulated_loss(step: int, total_steps: int, initial_loss: float = 2.5) -> float:
    """Simulate a realistic decreasing loss curve with noise."""
    import random  # local import — keeps module import fast

    rng = random.Random(42 + step)
    decay = math.exp(-3.0 * step / max(1, total_steps))
    noise = rng.gauss(0, 0.02)
    return max(0.05, initial_loss * decay + noise)


def _simulated_vram_gb(step: int) -> float:
    """Simulate VRAM usage (GB) that stabilises after warm-up."""
    import random

    rng = random.Random(99 + step)
    base = 6.5 + min(step * 0.1, 2.0)  # ramps up then stabilises
    return round(base + rng.gauss(0, 0.05), 2)


def train(steps: int = {{ steps }}, project_root: Path | None = None) -> dict:
    """Run a micro-training loop and return final metrics."""
    root = project_root or Path(__file__).parent.parent
    data_dir = root / "data"
    output_dir = root / "outputs"
    output_dir.mkdir(parents=True, exist_ok=True)

    rows = _load_dataset(data_dir)
    print(f"[train] loaded {len(rows)} rows — running {steps} steps")

    step_metrics = []
    wall_start = time.monotonic()

    for step in range(1, steps + 1):
        step_start = time.monotonic()
        loss = _simulated_loss(step, steps)
        # Simulate a mini-batch forward-backward pass
        time.sleep(0.001)
        elapsed = time.monotonic() - step_start
        vram = _simulated_vram_gb(step)

        step_metrics.append(
            {
                "step": step,
                "loss": round(loss, 6),
                "time_per_step_s": round(elapsed, 4),
                "vram_gb": vram,
            }
        )
        if step % max(1, steps // 5) == 0 or step == steps:
            print(f"  step {step:>4}/{steps}  loss={loss:.4f}  vram={vram:.1f}GB")

    total_time = time.monotonic() - wall_start
    final_loss = step_metrics[-1]["loss"] if step_metrics else float("nan")
    avg_time = total_time / steps if steps > 0 else 0.0

    metrics = {
        "steps": steps,
        "final_loss": final_loss,
        "avg_time_per_step_s": round(avg_time, 4),
        "total_time_s": round(total_time, 2),
        "final_vram_gb": step_metrics[-1]["vram_gb"] if step_metrics else 0.0,
        "step_history": step_metrics,
    }

    metrics_path = output_dir / "metrics.json"
    metrics_path.write_text(json.dumps(metrics, indent=2, ensure_ascii=False), encoding="utf-8")
    print(f"[train] metrics written to {metrics_path}")
    return metrics


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Micro LoRA training loop")
    parser.add_argument("--steps", type=int, default={{ steps }}, help="Number of training steps")
    parser.add_argument("--project-root", type=str, default=None)
    args = parser.parse_args()
    root = Path(args.project_root) if args.project_root else None
    result = train(steps=args.steps, project_root=root)
    print(json.dumps({"final_loss": result["final_loss"], "steps": result["steps"]}))
