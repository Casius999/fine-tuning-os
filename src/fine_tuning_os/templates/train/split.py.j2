#!/usr/bin/env python3
"""Seeded train/val/test split for a JSONL dataset.

Generated by Fine-Tuning OS — edit as needed.
Usage: python split.py --input data/dataset.jsonl --output-dir data/splits
"""
from __future__ import annotations

import argparse
import json
import random
from pathlib import Path


def split_jsonl(
    input_path: str,
    output_dir: str,
    train_ratio: float = {{ train }},
    val_ratio: float = {{ val }},
    test_ratio: float = {{ test }},
    seed: int = {{ seed }},
    stratify_key: str | None = {{ "None" if not stratify else '"label"' }},
) -> dict[str, int]:
    """Split a JSONL file into train/val/test subsets."""
    rng = random.Random(seed)
    rows: list[dict] = []
    with open(input_path, encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if line:
                rows.append(json.loads(line))

    if stratify_key and all(stratify_key in r for r in rows):
        # Stratified split: preserve label distribution
        from collections import defaultdict

        buckets: dict[str, list[dict]] = defaultdict(list)
        for row in rows:
            buckets[str(row[stratify_key])].append(row)
        train_rows, val_rows, test_rows = [], [], []
        for bucket in buckets.values():
            rng.shuffle(bucket)
            n = len(bucket)
            n_test = max(1, round(n * test_ratio))
            n_val = max(1, round(n * val_ratio))
            test_rows.extend(bucket[:n_test])
            val_rows.extend(bucket[n_test : n_test + n_val])
            train_rows.extend(bucket[n_test + n_val :])
    else:
        rng.shuffle(rows)
        n = len(rows)
        n_test = max(1, round(n * test_ratio))
        n_val = max(1, round(n * val_ratio))
        test_rows = rows[:n_test]
        val_rows = rows[n_test : n_test + n_val]
        train_rows = rows[n_test + n_val :]

    out = Path(output_dir)
    out.mkdir(parents=True, exist_ok=True)
    splits = {"train": train_rows, "val": val_rows, "test": test_rows}
    counts: dict[str, int] = {}
    for name, subset in splits.items():
        dest = out / f"{name}.jsonl"
        with dest.open("w", encoding="utf-8") as fh:
            for row in subset:
                fh.write(json.dumps(row, ensure_ascii=False) + "\n")
        counts[name] = len(subset)
    return counts


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Seeded JSONL splitter")
    parser.add_argument("--input", required=True)
    parser.add_argument("--output-dir", default="data/splits")
    parser.add_argument("--seed", type=int, default={{ seed }})
    args = parser.parse_args()
    counts = split_jsonl(args.input, args.output_dir, seed=args.seed)
    print(json.dumps(counts))
