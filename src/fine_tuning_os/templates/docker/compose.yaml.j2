# compose.yaml — generated by Fine-Tuning OS
# Image: {{ image }}
# Env vars are referenced by name; secrets are NEVER embedded here.

version: "3.9"

services:
  train:
    image: {{ image }}
    restart: "no"

    # GPU access — adjust count/capabilities for your hardware
    deploy:
      resources:
        reservations:
          devices:
{% if gpus %}
{% for gpu in gpus %}
            - driver: nvidia
              device_ids: ["{{ gpu }}"]
              capabilities: [gpu]
{% endfor %}
{% else %}
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}

    # Mount points for data / checkpoints / outputs
    volumes:
{% for mount in mounts %}
      - {{ mount.host }}:{{ mount.container }}{% if mount.get("readonly") %}:ro{% endif %}

{% endfor %}

    # Environment — names only, values injected from host shell or .env file
    environment:
{% for var_name in env_names %}
      - {{ var_name }}=${{"{"}}{{ var_name }}{{"}"}}
{% endfor %}

    # Never embed secrets; use env files or a secrets manager in production
    # env_file: .env  ← enable if preferred

    working_dir: /home/trainer/app
    shm_size: "2gb"
    ulimits:
      memlock:
        soft: -1
        hard: -1

  # Optional: inference sidecar (disabled by default)
  infer:
    image: {{ image }}
    profiles: ["infer"]
    command: ["python3", "src/infer.py"]
    depends_on:
      - train
    volumes:
{% for mount in mounts %}
      - {{ mount.host }}:{{ mount.container }}{% if mount.get("readonly") %}:ro{% endif %}

{% endfor %}
    environment:
{% for var_name in env_names %}
      - {{ var_name }}=${{"{"}}{{ var_name }}{{"}"}}
{% endfor %}
