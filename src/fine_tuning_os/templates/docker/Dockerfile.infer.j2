# Dockerfile.infer — generated by Fine-Tuning OS
# Engine: {{ engine }}
# Model: {{ model_path }}
# Generated: see project config for timestamp
# Security: non-root user, pinned base, no secrets in image

# ── Stage 1: base ───────────────────────────────────────────────────────────
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04 AS base

# Disable interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies (pinned to stable versions, no curl|sh pipelines)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-dev \
    python3-pip \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── Stage 2: non-root user + dependencies ───────────────────────────────────
FROM base AS deps

# Create a non-root service user
RUN useradd --create-home --shell /bin/bash inferuser
WORKDIR /home/inferuser/app

{% if engine == "vllm" %}
# vLLM: OpenAI-compatible API server
RUN pip install --no-cache-dir \
    vllm>=0.4.0 \
    fastapi>=0.110.0 \
    uvicorn[standard]>=0.29.0
{% elif engine == "sglang" %}
# SGLang: high-throughput inference runtime
RUN pip install --no-cache-dir \
    sglang[srt]>=0.2.0 \
    fastapi>=0.110.0 \
    uvicorn[standard]>=0.29.0
{% else %}
# Generic Hugging Face Transformers inference server
RUN pip install --no-cache-dir \
    transformers>=4.46.0 \
    accelerate>=1.1.0 \
    fastapi>=0.110.0 \
    uvicorn[standard]>=0.29.0
{% endif %}

# ── Stage 3: runtime ─────────────────────────────────────────────────────────
FROM deps AS runtime

USER inferuser

# Model path is passed at runtime via volume mount or env var.
# NEVER bake model weights or API keys into the image.
# Mount the model at /home/inferuser/models or set MODEL_PATH env var.
ENV MODEL_PATH="{{ model_path }}" \
    PORT="8000"

# API key is injected at runtime via environment variable.
# The image itself contains NO secret values.
# Pass: -e API_KEY=$API_KEY at docker run time.

{% if engine == "vllm" %}
EXPOSE 8000
ENTRYPOINT ["python3", "-m", "vllm.entrypoints.openai.api_server"]
CMD ["--model", "/home/inferuser/models", "--host", "0.0.0.0", "--port", "8000"]
{% elif engine == "sglang" %}
EXPOSE 8000
ENTRYPOINT ["python3", "-m", "sglang.launch_server"]
CMD ["--model-path", "/home/inferuser/models", "--host", "0.0.0.0", "--port", "8000"]
{% else %}
# Copy generic inference server script
COPY --chown=inferuser:inferuser src/serve.py ./src/serve.py
ENV PATH="/home/inferuser/.local/bin:${PATH}"
EXPOSE 8000
ENTRYPOINT ["python3", "src/serve.py"]
CMD ["--model", "/home/inferuser/models", "--port", "8000"]
{% endif %}
