# Dockerfile.train — generated by Fine-Tuning OS
# Base: {{ base_image }}
# Project: {{ project_id }}
# Generated: see project config for timestamp

# ── Stage 1: base ───────────────────────────────────────────────────────────
FROM {{ base_image }} AS base

# Disable interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies (pinned to stable versions, no curl|sh pipelines)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip \
    python3-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── Stage 2: dependencies ────────────────────────────────────────────────────
FROM base AS deps

# Create a non-root user early to avoid running pip as root
RUN useradd --create-home --shell /bin/bash trainer
WORKDIR /home/trainer/app

# Copy requirements first for layer caching
COPY --chown=trainer:trainer requirements.txt ./

# Install Python dependencies as the non-root user
USER trainer
RUN pip install --user --no-cache-dir -r requirements.txt

{% if cache_models %}
# Pre-cache model weights into the image (offline-friendly deployments)
# ARG is used so the value never ends up in ENV and leaks into processes
ARG MODEL_CACHE_DIR=/home/trainer/.cache/huggingface
ENV HF_HOME=${MODEL_CACHE_DIR}
{% endif %}

# ── Stage 3: runtime ─────────────────────────────────────────────────────────
FROM deps AS runtime

# Copy training script
COPY --chown=trainer:trainer src/train.py ./src/train.py

# Ensure local pip binaries are on PATH for the non-root user
ENV PATH="/home/trainer/.local/bin:${PATH}"

# Default entrypoint: run training script; override CMD in compose/k8s
ENTRYPOINT ["python3", "src/train.py"]
CMD ["--steps", "10"]
