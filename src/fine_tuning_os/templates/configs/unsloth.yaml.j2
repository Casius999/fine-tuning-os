# Unsloth QLoRA fine-tuning config — generated by Fine-Tuning OS
# Framework: unsloth
framework: unsloth

model:
  name: {{ base_model }}
  load_in_4bit: true
  max_seq_length: {{ max_seq_len }}

lora:
  r: {{ lora_rank }}
  lora_alpha: {{ lora_rank * 2 }}
  lora_dropout: 0.0
  target_modules:
    - q_proj
    - k_proj
    - v_proj
    - o_proj
    - gate_proj
    - up_proj
    - down_proj

training:
  per_device_train_batch_size: {{ batch_size }}
  gradient_accumulation_steps: 4
  num_train_epochs: {{ epochs }}
  learning_rate: {{ lr }}
  lr_scheduler_type: {{ scheduler }}
  warmup_ratio: 0.05
  fp16: false
  bf16: true
  packing: true
  seed: 42

output:
  output_dir: outputs/checkpoints
  save_strategy: epoch
  logging_steps: 10
  report_to: none
