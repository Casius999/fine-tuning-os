# Custom / HuggingFace Trainer LoRA config — generated by Fine-Tuning OS
# Framework: custom
framework: custom

model:
  name_or_path: {{ base_model }}
  trust_remote_code: false

peft:
  peft_type: LORA
  r: {{ lora_rank }}
  lora_alpha: {{ lora_rank * 2 }}
  lora_dropout: 0.05
  bias: none
  task_type: CAUSAL_LM
  target_modules:
    - q_proj
    - v_proj

training_arguments:
  output_dir: outputs/checkpoints
  num_train_epochs: {{ epochs }}
  per_device_train_batch_size: {{ batch_size }}
  per_device_eval_batch_size: {{ batch_size }}
  gradient_accumulation_steps: 4
  learning_rate: {{ lr }}
  lr_scheduler_type: {{ scheduler }}
  warmup_ratio: 0.05
  max_seq_length: {{ max_seq_len }}
  bf16: true
  fp16: false
  packing: true
  group_by_length: false
  save_strategy: epoch
  logging_steps: 10
  seed: 42
