# EditorConfig — https://editorconfig.org  (consistent style across all editors)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{js,jsx,ts,tsx,json,jsonc,yml,yaml,css,scss,html,md}]
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # preserve hard line breaks (two trailing spaces)
